{
  "name": "pt-rebuild",
  "version": "1.0.0",
  "description": "PT Tracker Rebuild - Supabase + Vercel",
  "scripts": {
    "beads:install-commit-hook": "git config core.hooksPath .beads/hooks && bd hooks install --beads",
    "dev": "next dev",
    "build": "next build",
    "biome:check": "biome check .",
    "biome:lint": "biome lint .",
    "biome:format": "biome format --write .",
    "biome:report": "node scripts/biome-report.mjs",
    "biome:report:summary": "node scripts/biome-report-summary.mjs",
    "biome:staged": "node scripts/run-biome-staged.mjs",
    "commit:preflight": "node scripts/commit-preflight.mjs",
    "structure:check": "node scripts/check-structure.mjs --staged",
    "analyze:bundle": "next experimental-analyze",
    "analyze:bundle:out": "next experimental-analyze -o",
    "analyze:paths": "node scripts/dump-analyzer-paths.mjs",
    "analyze:modules": "node scripts/dump-analyzer-module-graph.mjs",
    "start": "next start",
    "migrate": "node db/migrate.js",
    "deploy": "vercel --prod",
    "test:e2e": "playwright test",
    "test:e2e:headed": "playwright test --headed",
    "test:e2e:ui": "playwright test --ui",
    "beads:quickref": "node scripts/generate-beads-quickref.mjs",
    "dev-notes:build": "node scripts/generate-dev-notes.mjs",
    "dev-notes:check": "node scripts/generate-dev-notes.mjs --check",
    "sync-docs": "bash scripts/sync-migration-doc.sh"
  },
  "dependencies": {
    "@supabase/ssr": "^0.10.2",
    "@supabase/supabase-js": "^2.105.0",
    "@vercel/analytics": "^2.0.1",
    "@vercel/speed-insights": "^2.0.0",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "react-virtuoso": "^4.18.5"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.12",
    "@playwright/test": "^1.59.1",
    "@serwist/turbopack": "^9.5.7",
    "esbuild-wasm": "^0.28.0",
    "next": "^16.2.3",
    "serwist": "^9.5.7",
    "vercel": "^51.8.0"
  }
}
