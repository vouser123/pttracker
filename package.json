{
  "name": "pt-rebuild",
  "version": "1.0.0",
  "description": "PT Tracker Rebuild - Supabase + Vercel",
  "scripts": {
    "beads:install-commit-hook": "node ../scripts/install-beads-hooks.mjs",
    "readme:check": "node scripts/check-readme-update.mjs",
    "dev": "next dev",
    "build": "next build",
    "analyze:bundle": "next experimental-analyze -o",
    "analyze:paths": "node scripts/dump-analyzer-paths.mjs",
    "analyze:modules": "node scripts/dump-analyzer-module-graph.mjs",
    "start": "next start",
    "migrate": "node db/migrate.js",
    "deploy": "vercel --prod",
    "test:e2e": "playwright test",
    "test:e2e:headed": "playwright test --headed",
    "test:e2e:ui": "playwright test --ui",
    "beads:quickref": "node scripts/generate-beads-quickref.mjs",
    "dev-notes:build": "node scripts/generate-dev-notes.mjs",
    "dev-notes:check": "node scripts/generate-dev-notes.mjs --check",
    "sync-docs": "bash scripts/sync-migration-doc.sh"
  },
  "dependencies": {
    "@supabase/ssr": "^0.9.0",
    "@supabase/supabase-js": "^2.90.1",
    "@vercel/analytics": "^2.0.1",
    "@vercel/speed-insights": "^2.0.0",
    "next": "^16.2.1",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "react-virtuoso": "^4.18.3"
  },
  "devDependencies": {
    "@playwright/test": "^1.58.2",
    "vercel": "^33.0.0"
  }
}
