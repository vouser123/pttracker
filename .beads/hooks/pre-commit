#!/usr/bin/env sh
# --- BEGIN BEADS INTEGRATION v1.0.0 ---
# This section is managed by beads. Do not remove these markers.
if command -v bd >/dev/null 2>&1; then
  export BD_GIT_HOOK=1
  _bd_timeout=${BEADS_HOOK_TIMEOUT:-300}
  if command -v timeout >/dev/null 2>&1; then
    timeout "$_bd_timeout" bd hooks run pre-commit "$@"
    _bd_exit=$?
    if [ $_bd_exit -eq 124 ]; then
      echo >&2 "beads: hook 'pre-commit' timed out after ${_bd_timeout}s — continuing without beads"
      _bd_exit=0
    fi
  else
    bd hooks run pre-commit "$@"
    _bd_exit=$?
  fi
  if [ $_bd_exit -eq 3 ]; then
    echo >&2 "beads: database not initialized — skipping hook 'pre-commit'"
    _bd_exit=0
  fi
  if [ $_bd_exit -ne 0 ]; then exit $_bd_exit; fi
fi
# --- END BEADS INTEGRATION v1.0.0 ---
# --- BEGIN PTTRACKER README CHECK ---
readme_path="README.md"

if [ "${PT_README_OK:-0}" != "1" ]; then
  git_prefix="$(git rev-parse --show-prefix 2>/dev/null | tr '\\' '/' || true)"
  staged_files="$(git diff --cached --name-only --diff-filter=ACMR | tr '\\' '/')"

  shared_files=""
  for file in $staged_files; do
    trimmed="$file"
    if [ -n "$git_prefix" ]; then
      case "$trimmed" in
        "$git_prefix"*)
          trimmed="${trimmed#"$git_prefix"}"
          ;;
      esac
    fi

    case "$trimmed" in
      pages/*|components/*|hooks/*|lib/*|api/*|styles/globals.css)
        shared_files="${shared_files}${trimmed}\n"
        ;;
      public/index.html|public/pt_view.html|public/pt_editor.html|public/rehab_coverage.html|public/manifest.json|public/manifest-tracker.json)
        shared_files="${shared_files}${trimmed}\n"
        ;;
    esac
  done

  if [ -n "$shared_files" ] && ! printf '%s\n' "$staged_files" | grep -Fxq "$readme_path"; then
    printf '%s\n' >&2 "README review required before commit."
    printf '%s\n' >&2 ""
    printf '%s\n' >&2 "You staged shared ownership or route-shape files that can change the agent-ops map:"
    printf '%b' "$shared_files" | while IFS= read -r shared_file; do
      if [ -n "$shared_file" ]; then
        printf '  - %s\n' "$shared_file" >&2
      fi
    done
    printf '%s\n' >&2 ""
    printf '%s\n' >&2 "Stage README.md if the ownership map, route map, or shared-file guidance changed."
    printf '%s\n' >&2 "If the README remains accurate without edits, retry with:"
    printf '%s\n' >&2 '  $env:PT_README_OK="1"; git commit ...'
    printf '%s\n' >&2 ""
    printf '%s\n' >&2 "See README.md and AGENTS.md."
    exit 1
  fi
fi
# --- END PTTRACKER README CHECK ---

# --- BEGIN PTTRACKER BIOME AUTOFORMAT ---
if command -v node >/dev/null 2>&1; then
  node scripts/run-biome-staged.mjs
  _biome_exit=$?
  if [ $_biome_exit -ne 0 ]; then exit $_biome_exit; fi
  node scripts/check-structure.mjs --staged
  _structure_exit=$?
  if [ $_structure_exit -ne 0 ]; then exit $_structure_exit; fi
fi
# --- END PTTRACKER BIOME AUTOFORMAT ---

# --- BEGIN PTTRACKER GITLEAKS SECRET SCAN ---
if command -v powershell >/dev/null 2>&1; then
  powershell -NoProfile -ExecutionPolicy Bypass -File scripts/run-gitleaks-staged.ps1
  _gitleaks_exit=$?
  if [ $_gitleaks_exit -ne 0 ]; then exit $_gitleaks_exit; fi
fi
# --- END PTTRACKER GITLEAKS SECRET SCAN ---
